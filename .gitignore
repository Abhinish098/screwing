# Root .gitignore — The Duel monorepo

# Node
node_modules/
dist/
dist-ssr/
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment secrets — NEVER commit these
.env
server/.env

# Python / Alembic
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# Editor
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
